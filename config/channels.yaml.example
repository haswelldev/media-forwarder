# Media Forwarder Configuration
# This file defines which Telegram channels to monitor and where to forward messages

# Telegram channels to monitor
channels:
  # Example: Monitor a public channel by username with default settings
  - channel: "@example_channel"  # or use numeric ID: -1001234567890
    destinations:
      - discord_main

  # Example: Monitor channel with per-channel settings
  - channel: "@media_channel"
    destinations:
      - discord_main
    settings:
      # Only forward messages with media (photos, videos, documents)
      media_only: true
      # Remove captions from media posts
      remove_captions: false
      # Translate captions to English
      translate_captions: true
      # Override max file size for this channel (optional)
      max_file_size_mb: 25
      # Override metadata inclusion (optional)
      include_channel_name: true
      include_timestamp: true

  # Example: Channel that only forwards media without captions
  - channel: "@no_captions_channel"
    destinations:
      - discord_main
    settings:
      media_only: true
      remove_captions: true
      translate_captions: false

  # Example: Channel with custom file size limit
  - channel: "-1001234567890"
    destinations:
      - discord_main
    settings:
      max_file_size_mb: 50

  # Example: Monitor a channel to multiple destinations
  - channel: "@third_channel"
    destinations:
      - discord_main
      - discord_backup

# Discord webhook destinations
discord_webhooks:
  # Main Discord channel with custom max file size
  discord_main:
    url: "https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE"
    max_file_size_mb: 25  # Override max file size for this destination

  # Backup Discord channel with higher limit (e.g., for Nitro server)
  discord_backup:
    url: "https://discord.com/api/webhooks/YOUR_BACKUP_WEBHOOK_URL_HERE"
    max_file_size_mb: 500  # Nitro servers support up to 500MB

  # Third destination using default global setting
  discord_archive:
    url: "https://discord.com/api/webhooks/YOUR_ARCHIVE_WEBHOOK_URL_HERE"
    # No max_file_size_mb - will use global default (10MB)

# Default application settings (used if not overridden per channel)
settings:
  # Maximum file size in MB to upload to Discord
  # Discord free tier: 25MB, Discord Nitro: 500MB
  max_file_size_mb: 10

  # Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
  log_level: INFO

  # Include channel name in forwarded messages
  include_channel_name: true

  # Include timestamp in forwarded messages
  include_timestamp: true
